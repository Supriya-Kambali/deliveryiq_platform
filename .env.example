# IBM DeliveryIQ — Environment Configuration
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# WHY .env FILES?
#   Configuration should NEVER be hardcoded in source code.
#   .env files keep sensitive values (API keys, passwords) separate
#   from code — so you can share code without sharing secrets.
#   The .gitignore excludes .env from git commits.

# ─────────────────────────────────────────────────────────────────
# LLM CONFIGURATION
# ─────────────────────────────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3
# Alternative: OLLAMA_MODEL=mistral

# ─────────────────────────────────────────────────────────────────
# VECTOR DATABASE
# ─────────────────────────────────────────────────────────────────
CHROMADB_HOST=localhost
CHROMADB_PORT=8002
CHROMA_COLLECTION_NAME=ibm_delivery_knowledge

# ─────────────────────────────────────────────────────────────────
# EMBEDDING MODEL
# ─────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ─────────────────────────────────────────────────────────────────
# APP CONFIGURATION
# ─────────────────────────────────────────────────────────────────
APP_NAME=IBM DeliveryIQ
APP_VERSION=1.0
DEBUG=false

# ─────────────────────────────────────────────────────────────────
# OPTIONAL: HuggingFace (for downloading models)
# Get your token at: https://huggingface.co/settings/tokens
# ─────────────────────────────────────────────────────────────────
# HUGGINGFACE_TOKEN=hf_your_token_here

# ─────────────────────────────────────────────────────────────────
# OPTIONAL: LangSmith (for agent monitoring/debugging)
# Get your key at: https://smith.langchain.com
# ─────────────────────────────────────────────────────────────────
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=ls_your_key_here
# LANGCHAIN_PROJECT=ibm-deliveryiq